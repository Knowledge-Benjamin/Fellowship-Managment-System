# ==============================================================================
# DATABASE CONFIGURATION (Neon Serverless Postgres)
# ==============================================================================
#
# Neon provides two different connection strings: a Pooled string and a Direct string.
#
# 1. DATABASE_URL (Pooled Connection)
#    - Used for standard application queries.
#    - Handles thousands of concurrent user connections efficiently without overloading Postgres.
#    - How to get it in Neon Dashboard:
#      Go to your Project Dashboard -> "Connection Details" -> Check the "Pooled connection" box.
#      It typically looks like: postgresql://[user]:[password]@[endpoint]-pooler.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://username:password@localhost:5432/fellowship_manager?schema=public"

# 2. DIRECT_URL (Direct Connection)
#    - Used ONLY by Prisma for executing structural database migrations (like building new indexes).
#    - Required because Prisma CLI structural changes cannot be routed through a connection pooler.
#    - How to get it in Neon Dashboard:
#      Go to your Project Dashboard -> "Connection Details" -> UNCHECK the "Pooled connection" box.
#      It typically looks exactly like the DB URL but without the "-pooler" tag.
DIRECT_URL="postgresql://username:password@localhost:5432/fellowship_manager?schema=public"

# ==============================================================================
# AUTH & SECURITY
# ==============================================================================

JWT_SECRET=your_jwt_secret_key_change_in_production

# SendGrid Configuration (Primary Email Provider - RECOMMENDED)
# Sign up for free at: https://signup.sendgrid.com/ (100 emails/day)
# Generate API key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your_verified_email@example.com

# Gmail SMTP for OTP emails (Fallback)
# IMPORTANT: Use App-Specific Password, not your regular Gmail password
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
